{
  "name": "ai-furniture-hub",
  "version": "6.4.0",
  "description": "MCP server for AI agents: 18 tools, 355+ curated products, 31 categories, 90+ brands. mm-precision furniture search, photo-to-dimension measurement, carry-in path checker, demand analysis, curated sets, replacement finder with fit_score & 25-entry compatibility DB, AI visibility diagnosis, Rakuten live API. Japan-focused home & lifestyle hub.",
  "main": "dist/index.js",
  "bin": {
    "ai-furniture-hub": "dist/index.js"
  },
  "files": [
    "dist/",
    "public/",
    "shared/",
    ".well-known/"
  ],
  "scripts": {
    "start": "ts-node index.ts",
    "start:http": "ts-node server_http.ts",
    "dev": "ts-node index.ts",
    "dev:http": "ts-node server_http.ts",
    "test": "ts-node test/run_test.ts",
    "test:phase2": "ts-node test/run_phase2_test.ts",
    "test:all": "ts-node test/run_test.ts && ts-node test/run_gap_test.ts && ts-node test/run_evolution_test.ts && ts-node test/run_affiliate_test.ts && ts-node test/run_phase2_test.ts && ts-node test/run_rakuten_test.ts",
    "test:ci": "vitest run",
    "test:watch": "vitest",
    "build": "tsc",
    "start:render": "node dist/server_http.js",
    "review:proposals": "ts-node scripts/review_proposals.ts",
    "review:research": "ts-node scripts/review_research.ts",
    "review:approve": "ts-node scripts/review_research.ts --approve",
    "review:stats": "ts-node scripts/review_research.ts --stats",
    "analyze": "ts-node scripts/analyze_demand.ts",
    "report:opportunities": "ts-node scripts/report_product_opportunities.ts",
    "sync-log": "ts-node scripts/sync_log.ts",
    "report": "ts-node scripts/report_conversions.ts",
    "enrich": "ts-node scripts/enrich_catalog.ts",
    "research": "ts-node scripts/research.ts",
    "research:context": "ts-node scripts/research.ts --context",
    "review:coord": "ts-node scripts/review_coordination.ts",
    "review:coord:approve": "ts-node scripts/review_coordination.ts --approve",
    "review:coord:stats": "ts-node scripts/review_coordination.ts --stats",
    "review:coord:sample": "ts-node scripts/review_coordination.ts --sample",
    "enrich:gaps": "ts-node scripts/review_enrichment.ts --gaps",
    "enrich:review": "ts-node scripts/review_enrichment.ts",
    "enrich:approve": "ts-node scripts/review_enrichment.ts --approve",
    "enrich:stats": "ts-node scripts/review_enrichment.ts --stats",
    "enrich:sample": "ts-node scripts/review_enrichment.ts --sample"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "mcp-registry",
    "furniture",
    "ai",
    "ai-agent",
    "agent",
    "cursor",
    "claude",
    "chatgpt",
    "vscode",
    "rakuten",
    "amazon",
    "storage",
    "dimensions",
    "affiliate",
    "smart-home",
    "appliances",
    "beauty",
    "gadgets",
    "llms-txt",
    "model-context-protocol",
    "product-search",
    "japan",
    "e-commerce",
    "openapi",
    "curated"
  ],
  "author": "ONE, Inc.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ONE8943/ai-furniture-hub"
  },
  "homepage": "https://ai-furniture-hub.onrender.com",
  "mcpName": "io.github.ONE8943/ai-furniture-hub",
  "type": "commonjs",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@smithery/sdk": "^4.3.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.2",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@smithery/cli": "^4.7.4",
    "esbuild": "^0.28.0",
    "vitest": "^4.1.4"
  }
}
