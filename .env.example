# =============================================================
# MCP Hub - アフィリエイト設定（環境変数）
# このファイルを .env にコピーして実際のIDを入力してください
# .env は .gitignore に含め、絶対にコミットしないこと
# =============================================================

# ── ニトリ（バリューコマース経由）──────────────────────────
AFFILIATE_ID_NITORI=your_nitori_id_here

# ── 楽天アフィリエイト ────────────────────────────────────
# ドット区切り4パート形式（例: 52b5b3f6.d649457f.52b5b3f7.c31ecd10）
AFFILIATE_ID_RAKUTEN=your_rakuten_id_here

# ── Amazon アソシエイト ───────────────────────────────────
AFFILIATE_ID_AMAZON=your_amazon_associate_id_here

# ── バリューコマース（汎用）──────────────────────────────
AFFILIATE_ID_VALUECOMMERCE=your_vc_id_here

# ── 楽天API設定 ──────────────────────────────────────────
# https://webservice.rakuten.co.jp/app/list で発行
RAKUTEN_APP_ID=your_app_id_here
RAKUTEN_ACCESS_KEY=your_access_key_here
# true にすると楽天APIを叩かずモックデータを返す（テスト用）
RAKUTEN_API_MOCK=true

# ── MCP Hub 設定 ──────────────────────────────────────────
# UTMパラメータのソース（アナリティクス追跡用）
UTM_SOURCE=mcp_hub
UTM_MEDIUM=ai_agent
