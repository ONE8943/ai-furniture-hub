# =============================================================
# MCP Hub - アフィリエイト設定（環境変数）
# このファイルを .env にコピーして実際のIDを入力してください
# .env は .gitignore に含め、絶対にコミットしないこと
# =============================================================

# ── ニトリ（バリューコマース経由）──────────────────────────
AFFILIATE_ID_NITORI=your_nitori_id_here

# ── 楽天アフィリエイト ────────────────────────────────────
# ドット区切り4パート形式（例: xxxxxxxx.xxxxxxxx.xxxxxxxx.xxxxxxxx）
AFFILIATE_ID_RAKUTEN=your_rakuten_id_here

# ── Amazon アソシエイト ───────────────────────────────────
AFFILIATE_ID_AMAZON=your_amazon_associate_id_here

# ── バリューコマース（汎用）──────────────────────────────
AFFILIATE_ID_VALUECOMMERCE=your_vc_id_here

# ── 楽天API設定 ──────────────────────────────────────────
# https://webservice.rakuten.co.jp/app/list で発行
RAKUTEN_APP_ID=your_app_id_here
RAKUTEN_ACCESS_KEY=your_access_key_here
# true にすると楽天APIを叩かずモックデータを返す（テスト用）
RAKUTEN_API_MOCK=true

# ── Amazon PA-API設定 ─────────────────────────────────────
# https://affiliate.amazon.co.jp/assoc_credentials/home で発行
AMAZON_PA_ACCESS_KEY=your_access_key_here
AMAZON_PA_SECRET_KEY=your_secret_key_here
# true にするとAmazon PA-APIを叩かずモックデータを返す（テスト用）
AMAZON_API_MOCK=true

# ── MCP Hub 設定 ──────────────────────────────────────────
# UTMパラメータのソース（アナリティクス追跡用）
UTM_SOURCE=mcp_hub
UTM_MEDIUM=ai_agent

# ── デプロイモード ──────────────────────────────────────────
# private = 自前運用（アフィリエイト有効）
# public  = Apify/RapidAPI等へ公開（アフィリエイト無効・素URL返却）
DEPLOYMENT_MODE=private

# ── APIキー管理（レート制限ティア） ──────────────────────
# カンマ区切りで複数キーを登録可能
# MCP_API_KEYS_FREE=fk_abc123,fk_def456
# MCP_API_KEYS_PRO=pk_xyz789

# ── レガシーAPIキー（旧MCP_API_KEY → Pro扱い） ───────────
# MCP_API_KEY=your_legacy_key_here

# ── 記録係（scripts/sync_log.ts）──────────────────────────
# Google AI Studio / Vertex で発行。未設定なら npm run sync-log は起動しない。
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_API_KEY=your_key_here
