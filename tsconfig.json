{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "include": [
    "index.ts",
    "server_http.ts",
    "src/**/*.ts",
    "lib/**/*.ts",
    "schemas/**/*.ts",
    "data/**/*.ts",
    "utils/**/*.ts",
    "tools/**/*.ts",
    "adapters/**/*.ts",
    "services/**/*.ts",
    "shared/**/*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
